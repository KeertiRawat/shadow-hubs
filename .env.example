# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

# UN Comtrade API (free at https://comtradeplus.un.org/)
COMTRADE_API_KEY=your_comtrade_subscription_key_here

# Neo4j AuraDB (free tier at https://console.neo4j.io/)
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=your_auradb_username
NEO4J_PASSWORD=your_auradb_password_here
NEO4J_DATABASE=your_auradb_database_name

# OpenAI API (required for GraphRAG)
OPENAI_API_KEY=your_openai_api_key_here
